{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "finalprojobs360",
  "main": "worker.js",
  "compatibility_date": "2026-04-28",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": [
      "/signup"
    ]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
